# Copy to .env and fill in values. Auto-loaded by CLI, Config.load(), and resolve_* helpers.
# Environment variables override config.yaml.

api_key=sk-...
api_base_url=https://api.openai.com/v1

# Azure OpenAI (uncomment and set azure_subscription=true)
# azure_subscription=true
# api_key=<azure-api-key>
# azure_endpoint=https://<resource>.openai.azure.com/
# api_version=2024-10-21

# Model ids (optional — override config.yaml models.*)
compression_model=gpt-4o-mini
routing_model=gpt-4o-mini
evaluation_model=gpt-4o-mini
